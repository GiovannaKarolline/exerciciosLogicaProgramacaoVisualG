Algoritmo "4d - media escolar com exame"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Ler quatro valores referentes a quatro notas escolares de um
// aluno e imprimir uma mensagem dizendo que o aluno foi aprovado, se o valor
// da média escolar for maior ou igual a 7. Se o valor da média for menor que
// 7, solicitar a nota de exame, somar com o valor da média e obter nova média.
// Se a nova média for maior ou igual a 5, apresentar uma mensagem dizendo que
// o aluno foi aprovado em exame. Se o aluno năo foi aprovado, indicar uma
// mensagem informando esta condiçăo. Apresentar com as mensagens o valor da
// média do aluno, para qualquer condiçăo.
// Autor(a)    : Giovanna Karolline Menezes Ribeiro
// Data atual  : 28/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   nota1: real
   nota2: real
   nota3: real
   nota4: real
   notaExame: real
   media: real
   mediaExame: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Cálculo de resultado escolar")
   escreval("Digite o valor da primeira nota:")
   leia(nota1)
   escreval("Digite o valor da segunda nota:")
   leia(nota2)
   escreval("Digite o valor da terceira nota:")
   leia(nota3)
   escreval("Digite o valor da quarta nota:")
   leia(nota4)
   escreval("")

   media <- (nota1+nota2+nota3+nota4)/4

   se media < 7 entăo
      escreval("Digite o valor da nota do exame de recuperaçăo:")
      leia(notaExame)
      escreval("")
      media <- (media+notaExame)/2
      se media < 5 entăo
         escreval("Aluno reprovado.")
         escreval("Média pós-exame:",media)
      senăo
         escreval("Aluno aprovado em exame.")
         escreval("Média pós-exame:",media)
      fimse
   senăo
      escreval("Aluno aprovado.")
      escreval("Média das notas:",media)
   fimse

Fimalgoritmo