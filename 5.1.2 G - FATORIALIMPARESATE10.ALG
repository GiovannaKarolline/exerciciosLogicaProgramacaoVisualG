Algoritmo "5.1.2 g - fatorialImparesAte10"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : g) Elaborar um programa que apresente como resultado o valor
//do fatorial dos valores ímpares situados na faixa numérica de 1 a 10.
// Autor(a)    : Giovanna Karolline Menezes Ribeiro
// Data atual  : 23/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   contadora: inteiro
   contadora2: inteiro
   fatorial: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Fatorial dos números ímpares entre 1 e 10")
   repita
      se contadora mod 2 = 1 entăo
         fatorial <- contadora
         contadora2 <- contadora - 1
         se contadora2 > 0 entăo
            repita
               fatorial <- fatorial * contadora2
               contadora2 <- contadora2 - 1
            até contadora2 < 1
         senăo
            fatorial <- 1
         fimse
         escreval("O fatorial de",contadora," é",fatorial,".")
      fimse
      contadora <- contadora + 1
   até contadora > 10

Fimalgoritmo