Algoritmo "4e - equacaoSegundoGrau"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Efetuar a leitura de tręs valores (variáveis A, B e C) e
// efetuar o cálculo da equaçăo completa de segundo grau, apresentando as
// duas raízes, se para os valores informados for possível efetuar o
// referido cálculo. Lembre-se de que a variável A deve ser diferente de zero.
// Autor(a)    : Giovanna Karolline Menezes Ribeiro
// Data atual  : 28/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   a: real
   b: real
   c: real
   delta: real
   raiz1: real
   raiz2: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Cálculo de equaçăo de segundo grau")
   escreval("Digite o valor de 'a':")
   leia(a)
   se a = 0 entăo
      escreval("o valor de 'a' năo pode ser zero.")
      fimalgoritmo
   fimse
   escreval("Digite o valor de 'b':")
   leia(b)
   escreval("Digite o valor de 'c':")
   leia(c)
   escreval("")

   delta <- (b)^2 - 4*(a)*(c)

   se delta < 0 entăo
      escreval("Delta negativo. Năo é possível calcular as raízes.")
      fimalgoritmo
   fimse
   
   raiz1 <- (-b + raizq(delta))/(2*a)
   raiz2 <- (-b - raizq(delta))/(2*a)
   
   escreval("raiz 1:",raiz1:9:4)
   escreval("raiz 2:",raiz2:9:4)

Fimalgoritmo