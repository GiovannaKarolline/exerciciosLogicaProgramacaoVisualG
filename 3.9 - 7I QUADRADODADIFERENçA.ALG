Algoritmo "3.9 - 7i quadradoDaDiferença"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Ler dois inteiros (variáveis A e B) e imprimir o resultado
// do quadrado da diferença do primeiro valor pelo segundo.
// Autor(a)    : Giovanna Karolline Menezes Ribeiro
// Data atual  : 22/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   A: inteiro
   B: inteiro
   resultado: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Cálculo do quadrado da diferença entre dois números")
   escreva("Digite o valor de A (inteiro): ")
   leia(A)
   escreva("Digite o valor de B (inteiro): ")
   leia(B)
   escreval("")
   resultado <- (A - B) * (A - B)
   escreval("O quadrado da diferença de A por B é ", resultado,".")

Fimalgoritmo