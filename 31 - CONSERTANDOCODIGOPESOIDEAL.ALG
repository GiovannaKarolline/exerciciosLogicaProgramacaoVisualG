Algoritmo "31 - consertandoCodigoPesoIdeal"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : 31) Para o enunciado a seguir foi elaborado um algoritmo em
// Portuguęs Estruturado que contém erros, identifique os erros no algoritmo
// apresentado abaixo:
// Enunciado: Tendo como dados de entrada o nome, a altura e o sexo (M ou F)
// de uma pessoa, calcule e mostre seu peso ideal, utilizando as seguintes
// fórmulas:
// - para sexo masculino: peso ideal = (72.7 * altura) - 58
// - para sexo feminino: peso ideal = (62.1 * altura) - 44.7
// inicio
//    ler nome
//    ler sexo
//    se sexo = M entăo
//       peso_ideal <- (72.7 * altura) - 58
//    senăo
//       peso_ideal <- (62.1 * altura) – 44.7
//    fim_se
//    escrever peso_ideal
// fim
// Autor(a)    : Giovanna Karolline Menezes Ribeiro
// Data atual  : 18/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   nome: caractere
   sexo: caractere
   altura: real
   pesoIdeal: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Cálculo de peso ideal")
   escreval("Digite seu nome:")
   leia(nome)
   escreval("Digite sua altura:")
   leia(altura)
   escreval("Digite seu sexo (M ou F):")
   leia(sexo)
   escreval("")
   se sexo = "M" entăo
      pesoIdeal <- (72.7 * altura) - 58
   senăo
      pesoIdeal <- (62.1 * altura) - 44.7
   fimse
   escreval(nome,", o seu peso ideal é ", pesoIdeal:3:2, "Kg")

Fimalgoritmo